# Copy this file to .env.local for local development.
# Keep .env.local private. Do not commit or paste real keys into docs/logs.

# OpenAI-compatible LLM provider. Leave empty to use the built-in demo fallback.
OPENAI_API_KEY=replace_with_your_openai_or_compatible_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Alternative provider variable names also supported by lib/ai/provider.ts.
LLM_API_KEY=
LLM_MODEL=

# Azure Speech. Leave empty to use Web Speech / text fallback.
AZURE_SPEECH_KEY=replace_with_your_azure_speech_key
AZURE_SPEECH_REGION=eastasia

# Dev-only operations controls. These are ignored in production builds.
# FACEWALL_DEMO_MODE: auto | fallback
FACEWALL_DEMO_MODE=auto
# FACEWALL_DEV_FAULTS: comma-separated llm,tts
FACEWALL_DEV_FAULTS=
